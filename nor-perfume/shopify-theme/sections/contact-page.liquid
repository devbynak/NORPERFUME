<section class="support-page">

  <!-- Header -->
  <header class="support-header">
    <span class="support-eyebrow">Support</span>
    <h1 class="support-title">Connect With<br><em>Our Team</em></h1>
    <p class="support-subtitle">Whether it's a product question, order issue, or partnership inquiry — our team is ready to help.</p>
  </header>

  <!-- Quick Connect Cards -->
  <div class="support-channels">

    <a href="https://wa.me/919445934433" target="_blank" rel="noopener" class="channel-card">
      <div class="channel-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
      </div>
      <h3>WhatsApp</h3>
      <p>Chat live with our team. Fastest way to get help.</p>
      <span class="channel-cta">+91 94459 34433 &rarr;</span>
    </a>

    <a href="mailto:norperfume.in@gmail.com" class="channel-card">
      <div class="channel-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      </div>
      <h3>Email</h3>
      <p>Detailed inquiries. We reply within 24 hours.</p>
      <span class="channel-cta">norperfume.in@gmail.com &rarr;</span>
    </a>

    <div class="channel-card">
      <div class="channel-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      </div>
      <h3>Hours</h3>
      <p>Mon — Sat: 10am – 7pm IST</p>
      <span class="channel-detail">Sunday: Closed</span>
    </div>

  </div>

  <!-- Divider -->
  <div class="support-divider">
    <span>or send us a message</span>
  </div>

  <!-- Contact Form -->
  <div class="support-form-wrap">
    {% form 'contact', id: 'support-form' %}
      {%- if form.posted_successfully? -%}
        <div class="support-success">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <p>Message sent. Our team will get back to you shortly.</p>
        </div>
      {%- elsif form.errors -%}
        <div class="support-error">
          <p>{{ form.errors | default_errors }}</p>
        </div>
      {%- endif -%}

      <div class="sf-row">
        <div class="sf-group">
          <label for="sf-name">Name</label>
          <input type="text" id="sf-name" name="contact[name]" placeholder="Your name" required autocomplete="name">
        </div>
        <div class="sf-group">
          <label for="sf-email">Email</label>
          <input type="email" id="sf-email" name="contact[email]" placeholder="you@example.com" required autocomplete="email">
        </div>
      </div>

      <div class="sf-row">
        <div class="sf-group">
          <label for="sf-phone">Phone (optional)</label>
          <input type="tel" id="sf-phone" name="contact[phone]" placeholder="+91" autocomplete="tel">
        </div>
        <div class="sf-group">
          <label for="sf-topic">Topic</label>
          <select id="sf-topic" name="contact[topic]">
            <option value="Product Question">Product Question</option>
            <option value="Order Issue">Order Issue</option>
            <option value="Shipping & Delivery">Shipping & Delivery</option>
            <option value="Returns & Refunds">Returns & Refunds</option>
            <option value="Wholesale / Franchise">Wholesale / Franchise</option>
            <option value="Private Labeling">Private Labeling</option>
            <option value="Other">Other</option>
          </select>
        </div>
      </div>

      <div class="sf-group sf-full">
        <label for="sf-message">How can we help?</label>
        <textarea id="sf-message" name="contact[body]" rows="5" placeholder="Describe your question or issue..." required></textarea>
      </div>

      <button type="submit" class="sf-submit">Send Message</button>
    {% endform %}
  </div>

</section>

<style>
  .support-page {
    padding: 130px 2rem 80px;
    max-width: 900px;
    margin: 0 auto;
  }

  .support-header {
    text-align: center;
    margin-bottom: 56px;
  }
  .support-eyebrow {
    display: block;
    font-family: var(--sans);
    font-size: .62rem;
    font-weight: 500;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: rgba(245,240,235,.35);
    margin-bottom: 18px;
  }
  .support-title {
    font-family: var(--serif);
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    font-weight: 300;
    color: var(--c-cream);
    line-height: 1.1;
    margin-bottom: 16px;
  }
  .support-title em { color: var(--c-silver); }
  .support-subtitle {
    font-size: .88rem;
    color: rgba(245,240,235,.4);
    font-weight: 300;
    max-width: 440px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Channel cards */
  .support-channels {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 56px;
  }
  .channel-card {
    padding: 28px 24px;
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 14px;
    background: rgba(255,255,255,.02);
    transition: border-color .3s ease, transform .3s ease, background .3s ease;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  a.channel-card:hover {
    border-color: rgba(255,255,255,.2);
    background: rgba(255,255,255,.04);
    transform: translateY(-3px);
  }
  .channel-icon {
    color: rgba(245,240,235,.45);
    margin-bottom: 4px;
  }
  .channel-card h3 {
    font-family: var(--sans);
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--c-cream);
    margin: 0;
  }
  .channel-card p {
    font-size: .8rem;
    color: rgba(245,240,235,.4);
    font-weight: 300;
    line-height: 1.5;
    margin: 0;
  }
  .channel-cta {
    font-size: .75rem;
    color: var(--c-cream);
    font-weight: 400;
    margin-top: auto;
    padding-top: 8px;
  }
  .channel-detail {
    font-size: .75rem;
    color: rgba(245,240,235,.35);
    font-weight: 300;
  }

  /* Divider */
  .support-divider {
    text-align: center;
    margin-bottom: 48px;
    position: relative;
  }
  .support-divider::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 1px;
    background: rgba(255,255,255,.08);
  }
  .support-divider span {
    position: relative;
    background: var(--c-bg);
    padding: 0 24px;
    font-size: .68rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(245,240,235,.3);
  }

  /* Form */
  .support-form-wrap { max-width: 900px; }
  .sf-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }
  .sf-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .sf-full { margin-bottom: 24px; }
  .sf-group label {
    font-family: var(--sans);
    font-size: .6rem;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(245,240,235,.45);
  }
  .sf-group input,
  .sf-group select,
  .sf-group textarea {
    background: rgba(255,255,255,.03);
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 10px;
    padding: 14px 16px;
    font-family: var(--sans);
    font-size: .85rem;
    color: var(--c-cream);
    outline: none;
    transition: border-color .25s ease;
    width: 100%;
  }
  .sf-group input::placeholder,
  .sf-group textarea::placeholder {
    color: rgba(245,240,235,.18);
    font-weight: 300;
  }
  .sf-group input:focus,
  .sf-group select:focus,
  .sf-group textarea:focus {
    border-color: rgba(255,255,255,.3);
  }
  .sf-group select {
    appearance: none;
    -webkit-appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='12' viewBox='0 0 24 24' fill='none' stroke='rgba(245,240,235,.4)' stroke-width='2' xmlns='http://www.w3.org/2000/svg'%3E%3Cpolyline points='6 9 12 15 18 9'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 14px center;
    padding-right: 36px;
    cursor: pointer;
  }
  .sf-group select option { background: #141414; color: var(--c-cream); }
  .sf-group textarea { resize: vertical; min-height: 120px; }
  .sf-submit {
    display: inline-flex;
    align-items: center;
    padding: 14px 44px;
    font-family: var(--sans);
    font-size: .68rem;
    font-weight: 600;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    border-radius: 50px;
    background: var(--c-cream);
    color: var(--c-bg);
    border: none;
    cursor: pointer;
    transition: background .25s ease, transform .25s ease;
  }
  .sf-submit:hover {
    background: var(--c-silver);
    transform: translateY(-2px);
  }

  .support-success {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 20px;
    border: 1px solid rgba(120,196,120,.2);
    border-radius: 12px;
    background: rgba(120,196,120,.06);
    margin-bottom: 28px;
    color: #a8d8a8;
    font-size: .85rem;
    line-height: 1.6;
  }
  .support-success svg { flex-shrink: 0; margin-top: 2px; color: #7ec47e; }
  .support-success p { margin: 0; }
  .support-error {
    padding: 16px 20px;
    border: 1px solid rgba(224,112,112,.2);
    border-radius: 12px;
    background: rgba(224,112,112,.06);
    margin-bottom: 28px;
    color: #e07070;
    font-size: .85rem;
  }
  .support-error p { margin: 0; }

  @media (max-width: 768px) {
    .support-channels { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .sf-row { grid-template-columns: 1fr; }
    .support-page { padding: 110px 1.2rem 60px; }
  }
</style>

{% schema %}
{
  "name": "Contact / Support",
  "tag": "div",
  "class": "section-contact-page",
  "settings": [],
  "presets": [{ "name": "Contact / Support" }]
}
{% endschema %}
