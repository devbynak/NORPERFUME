<section
  id="section-{{ section.id }}"
  class="panel panel-hero"
  data-section-id="{{ section.id }}"
  data-section-type="hero"
>
  <div class="hero-media">
    <div class="hero-bg-gradient"></div>
    <div class="hero-bg-logo-tile" style="background-image: url({{ 'norwhitelogo.png' | asset_url }})" aria-hidden="true"></div>
  </div>

  <div class="hero-body">
    <h1 class="hero-title reveal-text">
      <span class="line-wrap"><span class="line-inner">{{ section.settings.title_line_1 }}</span></span>
      <span class="line-wrap"><span class="line-inner"><span class="hero-ticker-wrap"><span class="hero-ticker" id="hero-ticker">Moves</span></span></span></span>
      <span class="line-wrap"><span class="line-inner hero-you-line">You</span></span>
    </h1>

    <p class="hero-sub reveal-text">{{ section.settings.subtitle }}</p>

    <div class="hero-ctas reveal-text">
      <a href="{{ section.settings.cta_primary_link | default: '/collections/all' }}" class="cta-primary">
        {{ section.settings.cta_primary_text }}
      </a>
      <a href="{{ section.settings.cta_ghost_link | default: '/pages/about' }}" class="cta-ghost">
        {{ section.settings.cta_ghost_text }}
      </a>
    </div>
  </div>

  {%- comment -%} Floating ambient cards {%- endcomment -%}
  <div class="hero-float-row">
    <div class="float-card fc-left reveal-text" aria-hidden="true">
      <span class="fc-label">{{ section.settings.card_left_label }}</span>
      <p class="fc-name">{{ section.settings.card_left_value }}</p>
      <span class="fc-notes">{{ section.settings.card_left_sub }}</span>
    </div>

    <div class="float-card fc-right reveal-text" aria-hidden="true">
      <div class="fc-stars">
        {%- assign star_count = section.settings.card_right_stars | times: 1 -%}
        {%- for i in (1..star_count) -%}&#9733;{%- endfor -%}
      </div>
      <p class="fc-rating">{{ section.settings.card_right_value }}</p>
      <span class="fc-notes">{{ section.settings.card_right_sub }}</span>
    </div>
  </div>

</section>

<script>
(function() {
  var words = ['Moves', 'Drives', 'Defines', 'Inspires', 'Follows'];
  var el = document.getElementById('hero-ticker');
  if (!el) return;

  var front = document.createElement('span');
  front.className = 'flip-front';
  front.textContent = words[0];

  var back = document.createElement('span');
  back.className = 'flip-back';
  back.textContent = words[0];

  el.textContent = '';
  el.appendChild(front);
  el.appendChild(back);

  /* Fix width to longest word so "You" never shifts */
  var wrap = el.closest('.hero-ticker-wrap');
  if (wrap) {
    var measure = document.createElement('span');
    measure.style.cssText = 'visibility:hidden;position:absolute;white-space:nowrap;font:inherit;';
    wrap.appendChild(measure);
    var maxW = 0;
    for (var w = 0; w < words.length; w++) {
      measure.textContent = words[w];
      var mw = measure.offsetWidth;
      if (mw > maxW) maxW = mw;
    }
    wrap.removeChild(measure);
    wrap.style.width = (maxW + 24) + 'px';
  }

  var idx = 0;
  var busy = false;

  setInterval(function() {
    if (busy) return;
    busy = true;

    var nextIdx = (idx + 1) % words.length;
    back.textContent = words[nextIdx];
    el.classList.add('flipping');

    setTimeout(function() {
      idx = nextIdx;
      front.textContent = words[idx];
      el.style.transition = 'none';
      el.classList.remove('flipping');
      void el.offsetWidth;
      el.style.transition = '';
      busy = false;
    }, 650);
  }, 3000);
})();
</script>

