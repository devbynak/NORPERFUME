<!-- ===================== ABOUT PAGE HERO HEADER ===================== -->
<header class="page-header about-page-header">
  <div class="container">
    {%- if section.settings.eyebrow != blank -%}
      <span class="eyebrow fade-up">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    <h1 class="sec-title fade-up" data-delay="100">
      {{ section.settings.title | default: page.title }}
    </h1>
    {%- if section.settings.subtitle != blank -%}
      <p class="about-subtitle fade-up" data-delay="200">{{ section.settings.subtitle }}</p>
    {%- endif -%}
  </div>
</header>

<!-- ===================== STORY BLOCK ===================== -->
{%- if page.content != blank -%}
  <section class="about-content">
    <div class="container">
      <div class="story-block fade-up">
        {{ page.content }}
      </div>
    </div>
  </section>
{%- endif -%}

<!-- ===================== EDITORIAL BLOCKS ===================== -->
{%- if section.blocks.size > 0 -%}
  {%- for block in section.blocks -%}

    {%- case block.type -%}

      {%- when 'editorial' -%}
        <!-- Editorial two-column layout (image + text + feature list) -->
        <section class="about-editorial-section" {{ block.shopify_attributes }}>
          <div class="container">
            <div
              class="panel-editorial"
              style="padding: 0; min-height: auto;"
            >
              <div class="editorial-layout{% if block.settings.image_position == 'right' %} editorial-layout-reversed{% endif %}">

                <!-- Visual side -->
                <div class="editorial-vis fade-up">
                  <div class="ed-img-frame">
                    {%- if block.settings.image != blank -%}
                      <img
                        class="ed-img-inner ed-img-tag"
                        src="{{ block.settings.image | image_url: width: 700 }}"
                        alt="{{ block.settings.image.alt | default: block.settings.heading | escape }}"
                        width="700"
                        loading="lazy"
                      >
                    {%- else -%}
                      <div class="ed-img-inner"></div>
                    {%- endif -%}
                  </div>

                  {%- if block.settings.badge_label != blank -%}
                    <div class="ed-badge fade-up" data-delay="150">
                      <span class="ed-badge-label">{{ block.settings.badge_label }}</span>
                      {%- if block.settings.badge_subtext != blank -%}
                        <p>{{ block.settings.badge_subtext }}</p>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                </div>

                <!-- Text side -->
                <div class="editorial-text fade-up" data-delay="100">
                  {%- if block.settings.eyebrow != blank -%}
                    <span class="eyebrow">{{ block.settings.eyebrow }}</span>
                  {%- endif -%}

                  {%- if block.settings.heading != blank -%}
                    <h2 class="sec-title">{{ block.settings.heading }}</h2>
                  {%- endif -%}

                  {%- if block.settings.body != blank -%}
                    <p class="body-copy">{{ block.settings.body }}</p>
                  {%- endif -%}

                  <!-- Feature list items -->
                  {%- assign has_features = false -%}
                  {%- for i in (1..4) -%}
                    {%- assign feat_title_key = 'feature_' | append: i | append: '_title' -%}
                    {%- assign feat_text_key  = 'feature_' | append: i | append: '_text' -%}
                    {%- if block.settings[feat_title_key] != blank -%}
                      {%- assign has_features = true -%}
                    {%- endif -%}
                  {%- endfor -%}

                  {%- if has_features -%}
                    <ul class="feat-list">
                      {%- for i in (1..4) -%}
                        {%- assign feat_title_key = 'feature_' | append: i | append: '_title' -%}
                        {%- assign feat_text_key  = 'feature_' | append: i | append: '_text' -%}
                        {%- if block.settings[feat_title_key] != blank -%}
                          <li>
                            <div class="feat-dot" aria-hidden="true"></div>
                            <div class="feat-body">
                              <strong>{{ block.settings[feat_title_key] }}</strong>
                              {%- if block.settings[feat_text_key] != blank -%}
                                <span>{{ block.settings[feat_text_key] }}</span>
                              {%- endif -%}
                            </div>
                          </li>
                        {%- endif -%}
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}

                  {%- if block.settings.cta_label != blank and block.settings.cta_url != blank -%}
                    <a href="{{ block.settings.cta_url }}" class="cta-primary about-cta">
                      {{ block.settings.cta_label }}
                    </a>
                  {%- endif -%}
                </div>

              </div><!-- /editorial-layout -->
            </div><!-- /panel-editorial -->
          </div><!-- /container -->
        </section>

      {%- when 'text_block' -%}
        <!-- Centered rich text block -->
        <section class="about-text-section" {{ block.shopify_attributes }}>
          <div class="container">
            <div class="story-block about-text-block fade-up">
              {%- if block.settings.eyebrow != blank -%}
                <span class="eyebrow">{{ block.settings.eyebrow }}</span>
              {%- endif -%}
              {%- if block.settings.heading != blank -%}
                <h2 class="sec-title">{{ block.settings.heading }}</h2>
              {%- endif -%}
              {%- if block.settings.body != blank -%}
                <div class="rte">{{ block.settings.body }}</div>
              {%- endif -%}
            </div>
          </div>
        </section>

      {%- when 'stats' -%}
        <!-- Stats / numbers row -->
        <section class="about-stats-section" {{ block.shopify_attributes }}>
          <div class="container">
            <div class="about-stats-grid fade-up">
              {%- for i in (1..4) -%}
                {%- assign stat_num_key   = 'stat_' | append: i | append: '_number' -%}
                {%- assign stat_label_key = 'stat_' | append: i | append: '_label' -%}
                {%- if block.settings[stat_num_key] != blank -%}
                  <div class="about-stat">
                    <span class="about-stat-number">{{ block.settings[stat_num_key] }}</span>
                    {%- if block.settings[stat_label_key] != blank -%}
                      <span class="about-stat-label">{{ block.settings[stat_label_key] }}</span>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        </section>

    {%- endcase -%}

  {%- endfor -%}
{%- endif -%}

