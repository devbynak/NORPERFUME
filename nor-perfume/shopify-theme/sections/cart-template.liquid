{%- if cart.item_count > 0 -%}

<section class="cart-page">
  <div class="container">

    <header class="cart-page__header">
      <a href="{{ routes.all_products_collection_url }}" class="cart-page__back" aria-label="Continue shopping">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      </a>
      <h1 class="cart-page__title">Cart</h1>
      <p class="cart-page__count">{{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }}</p>
    </header>

    <div class="cart-page__layout">

      <!-- ── ITEMS ── -->
      <div class="cart-page__items">
        {%- form 'cart', cart, id: 'cart-form' -%}

          {%- for item in cart.items -%}
            <div class="cart-item" data-index="{{ item.index | plus: 1 }}">

              {%- if item.image -%}
                <a href="{{ item.url }}" class="cart-item__image" tabindex="-1" aria-hidden="true">
                  <img
                    src="{{ item.image | image_url: width: 200 }}"
                    alt="{{ item.image.alt | default: item.product.title | escape }}"
                    width="90"
                    height="108"
                    loading="lazy"
                  >
                </a>
              {%- endif -%}

              <div class="cart-item__info">
                <a href="{{ item.url }}" class="cart-item__name">{{ item.product.title }}</a>
                {%- unless item.product.has_only_default_variant -%}
                  <span class="cart-item__variant">{{ item.variant.title }}</span>
                {%- endunless -%}
                {%- if item.selling_plan_allocation -%}
                  <span class="cart-item__variant">{{ item.selling_plan_allocation.selling_plan.name }}</span>
                {%- endif -%}
                <button
                  type="button"
                  class="cart-item__remove"
                  aria-label="Remove {{ item.product.title | escape }}"
                  data-index="{{ item.index | plus: 1 }}"
                >
                  Remove
                </button>
              </div>

              <div class="quantity-selector">
                <button type="button" class="qty-btn cart-qty-minus" data-index="{{ item.index | plus: 1 }}" aria-label="Decrease quantity">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/></svg>
                </button>
                <input
                  type="number"
                  id="Quantity-{{ item.index | plus: 1 }}"
                  name="updates[]"
                  value="{{ item.quantity }}"
                  min="0"
                  class="quantity-selector__input cart-qty-input"
                  aria-label="Quantity for {{ item.product.title | escape }}"
                  data-index="{{ item.index | plus: 1 }}"
                >
                <button type="button" class="qty-btn cart-qty-plus" data-index="{{ item.index | plus: 1 }}" aria-label="Increase quantity">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
                </button>
              </div>

              <span class="cart-item__price">{{ item.line_price | money }}</span>
            </div>
          {%- endfor -%}

          <noscript>
            <button type="submit" name="update" class="btn-continue" style="margin-top: 20px;">Update Cart</button>
          </noscript>

        {%- endform -%}
      </div>

      <!-- ── SUMMARY ── -->
      <aside class="cart-summary">
        <h2 class="cart-summary__title">Summary</h2>

        <div class="cart-summary__row">
          <span>Subtotal</span>
          <span id="cart-subtotal">{{ cart.total_price | money }}</span>
        </div>

        <div class="cart-summary__row">
          <span>Shipping</span>
          <span>Calculated at checkout</span>
        </div>

        {%- if cart.cart_level_discount_applications.size > 0 -%}
          {%- for discount in cart.cart_level_discount_applications -%}
            <div class="cart-summary__row" style="color: #a8d8a8;">
              <span>{{ discount.title }}</span>
              <span>&minus; {{ discount.total_allocated_amount | money }}</span>
            </div>
          {%- endfor -%}
        {%- endif -%}

        <div class="cart-summary__row is-total">
          <span>Total</span>
          <span class="cart-summary__amount">{{ cart.total_price | money }}</span>
        </div>

        <p class="cart-summary__note">Taxes and shipping calculated at checkout.</p>

        <a href="{{ routes.checkout }}" class="btn-checkout">Checkout</a>

        <div class="cart-trust">
          <div class="cart-trust__item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Secure Payment
          </div>
          <div class="cart-trust__item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            International Shipping
          </div>
        </div>


        {%- if additional_checkout_buttons and section.settings.show_dynamic_checkout -%}
          <div class="cart-dynamic-checkout" style="margin-top: 16px;">
            {{ content_for_additional_checkout_buttons }}
          </div>
        {%- endif -%}
      </aside>

    </div>
  </div>
</section>

{%- else -%}

<!-- ── EMPTY CART ── -->
<section class="empty-cart">
  <div class="empty-cart__icon" aria-hidden="true">
    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
      <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
      <line x1="3" y1="6" x2="21" y2="6"/>
      <path d="M16 10a4 4 0 0 1-8 0"/>
    </svg>
  </div>
  <h1 class="empty-cart__title">Nothing here yet</h1>
  <p class="empty-cart__msg">Explore our fragrances and find your signature scent.</p>
  <a href="{{ routes.all_products_collection_url }}" class="cta-primary">Shop Now</a>
</section>

{%- endif -%}

<script>
(function () {
  document.querySelectorAll('.cart-qty-minus').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var input = document.getElementById('Quantity-' + btn.dataset.index);
      if (input && parseInt(input.value, 10) > 0) {
        input.value = parseInt(input.value, 10) - 1;
        input.dispatchEvent(new Event('change', { bubbles: true }));
      }
    });
  });
  document.querySelectorAll('.cart-qty-plus').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var input = document.getElementById('Quantity-' + btn.dataset.index);
      if (input) {
        input.value = parseInt(input.value, 10) + 1;
        input.dispatchEvent(new Event('change', { bubbles: true }));
      }
    });
  });
  document.querySelectorAll('.cart-item__remove').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var input = document.getElementById('Quantity-' + btn.dataset.index);
      if (input) {
        input.value = 0;
        input.dispatchEvent(new Event('change', { bubbles: true }));
        document.getElementById('cart-form').submit();
      }
    });
  });
})();
</script>

{% schema %}
{
  "name": "Cart",
  "tag": "div",
  "class": "section-cart-template",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_dynamic_checkout",
      "label": "Show accelerated checkout (PayPal, Apple Pay)",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Cart"
    }
  ]
}
{% endschema %}
