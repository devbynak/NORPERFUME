<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}" class="no-js">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif %}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}
    </title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    <link rel="icon" type="image/x-icon" href="{{ 'favicon.ico' | asset_url }}">

    <!-- Canonical & hreflang -->
    <link rel="canonical" href="{{ canonical_url }}">

    <!-- Open Graph / Social -->
    <meta property="og:site_name" content="{{ shop.name }}">
    <meta property="og:url" content="{{ canonical_url }}">
    <meta property="og:title" content="{{ page_title | escape }}">
    <meta property="og:type" content="website">
    {%- if page_image -%}
      <meta property="og:image" content="https:{{ page_image | image_url: width: 1200 }}">
      <meta property="og:image:width" content="1200">
    {%- elsif settings.share_image != blank -%}
      <meta property="og:image" content="https:{{ settings.share_image | image_url: width: 1200 }}">
      <meta property="og:image:width" content="1200">
    {%- endif -%}
    {%- if page_description -%}
      <meta property="og:description" content="{{ page_description | escape }}">
    {%- endif -%}
    <meta name="twitter:card" content="summary_large_image">

    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <!-- Google Fonts: Cormorant Garamond + Jost -->
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Jost:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    >

    <!-- Theme stylesheet -->
    {{ 'style.css' | asset_url | stylesheet_tag }}

    <!-- Shopify required head content (analytics, scripts injected by apps, etc.) -->
    {{ content_for_header }}

    <!-- Inline CSS custom properties from theme settings -->
    <style>
      :root {
        --color-background: {{ settings.color_background }};
        --color-text: {{ settings.color_text }};
        --color-accent: {{ settings.color_accent }};
        --color-button-bg: {{ settings.color_button_bg }};
        --color-button-text: {{ settings.color_button_text }};
        --color-button-border: {{ settings.color_button_border }};
        --font-heading: 'Plus Jakarta Sans', 'Jost', system-ui, sans-serif;
        --font-body: 'Jost', system-ui, sans-serif;
        --serif: 'Plus Jakarta Sans', 'Jost', system-ui, sans-serif;
        --sans: 'Jost', system-ui, sans-serif;
      }
    </style>

    <script>
      // Replace no-js with js class as early as possible
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
    </script>
  </head>

  <body class="template-{{ template.name | handle }}{% if template.suffix != blank %} template-{{ template.name | handle }}-{{ template.suffix | handle }}{% endif %}">


    <!-- Skip to content (hidden, accessibility) -->
    <a class="skip-to-content-link" href="#MainContent" style="display:none;">
      {{ 'general.accessibility.skip_to_content' | t }}
    </a>

    <!-- Site Header -->
    {% section 'header' %}

    <!-- Main page content -->
    <main id="MainContent" class="main-content" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    <!-- Site Footer -->
    {% section 'footer' %}

    <!-- Cart drawer / overlay (rendered by header section or standalone) -->
    {%- if settings.cart_type == 'drawer' -%}
      {%- sections 'cart-drawer' -%}
    {%- endif -%}

    <!-- WhatsApp floating button -->
    {%- if settings.whatsapp_number != blank -%}
      <a
        class="whatsapp-float"
        href="https://wa.me/{{ settings.whatsapp_number | remove: '+' | remove: ' ' | remove: '-' }}"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="{{ 'general.social.whatsapp' | t }}"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
      </a>
    {%- endif -%}

    <!-- Floating Cart Bubble -->
    <a href="/cart" class="cart-bubble" id="cart-bubble" aria-label="View cart">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 0 1-8 0"/>
      </svg>
      <span class="cart-bubble-count" id="cart-bubble-count">{{ cart.item_count }}</span>
    </a>

    <style>
      .cart-bubble {
        position: fixed;
        bottom: 28px;
        right: 28px;
        z-index: 900;
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: rgba(10,10,10,.85);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255,255,255,.12);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--c-cream, #f5f0eb);
        text-decoration: none;
        box-shadow: 0 8px 32px rgba(0,0,0,.4);
        transition: transform .3s ease, border-color .3s ease, box-shadow .3s ease;
      }
      .cart-bubble:hover {
        transform: translateY(-3px) scale(1.05);
        border-color: rgba(255,255,255,.25);
        box-shadow: 0 12px 40px rgba(0,0,0,.5);
      }
      .cart-bubble-count {
        position: absolute;
        top: -4px;
        right: -4px;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: #fff;
        color: #0a0a0a;
        font-family: var(--sans, 'Jost', sans-serif);
        font-size: .6rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        line-height: 1;
      }
      .cart-bubble-count:empty,
      .cart-bubble-count[data-count="0"] {
        display: none;
      }
    </style>

    <!-- Theme JavaScript -->
    <script src="{{ 'main.js' | asset_url }}" defer="defer"></script>


  </body>
</html>
